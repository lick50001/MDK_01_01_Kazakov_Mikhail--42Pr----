<UserControl x:Class="ShopContent.View.Items.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShopContent.View.Items"
             mc:Ignorable="d" 
             HorizontalAlignment="Stretch" Margin="5">

    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF4Fc318"/>
            <Setter Property="BorderBrush" Value="#FF4Fc318"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFC34E18"/>
            <Setter Property="BorderBrush" Value="#FFC34E18"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.Effect>
            <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
        </Grid.Effect>

        <!-- Определяем колонки для основной сетки -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <!-- Для картинки и кнопок -->
            <ColumnDefinition Width="*"/>
            <!-- Для контента -->
        </Grid.ColumnDefinitions>

        <!-- Левая панель: картинка и кнопки -->
        <StackPanel Grid.Column="0" Margin="10,10,0,0">
            <Image Width="50" Height="50" Source="/Images/ic_item.png"/>
            <Button Style="{StaticResource Update}" Height="25" Content="Изменить" Width="55" FontSize="10" 
                    Command="{Binding OnEdit}" Margin="0,12,0,0">
                <Button.Effect>
                    <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Delete}" Height="25" Content="Удалить" Width="55" FontSize="10" 
                    Command="{Binding OnDelete}" Margin="0,10,0,0">
                <Button.Effect>
                    <DropShadowEffect Direction="270" BlurRadius="5" ShadowDepth="2" Opacity="0.5"/>
                </Button.Effect>
            </Button>
        </StackPanel>

        <!-- Правая панель: поля ввода -->
        <Grid Grid.Column="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Строка 0: Наименование -->
            <Label Content="Наименование:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Padding="0"/>
            <Label Content="Стоимость:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Padding="0"/>

            <!-- Строка 1: Поля Наименование и Стоимость -->
            <TextBox Text="{Binding Name}" Grid.Row="1" Grid.Column="0" Height="26" VerticalContentAlignment="Center" IsEnabled="False"/>
            <TextBox Text="{Binding Price}" Grid.Row="1" Grid.Column="2" Height="26" VerticalContentAlignment="Center" IsEnabled="False"/>

            <!-- Строка 2: Категория -->
            <Label Content="Категория:" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center" Padding="0" Margin="0,10,0,0"/>

            <!-- Строка 3: Поле Категория -->
            <TextBox Text="{Binding Category.Name}" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" Height="26" VerticalContentAlignment="Center" IsEnabled="False"/>

            <!-- Строка 4: Описание -->
            <Label Content="Описание:" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center" Padding="0" Margin="0,10,0,0"/>

            <!-- Строка 5: Поле Описание -->
            <TextBox Text="{Binding Description}" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Height="60" 
                     VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" IsEnabled="False"/>
        </Grid>
    </Grid>
</UserControl>